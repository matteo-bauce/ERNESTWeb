<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cookie Policy | ERNEST</title>
    <meta
      name="description"
      content="Cookie policy page for the ERNEST website."
    />
    <script>
      (() => {
        try {
          const consent = JSON.parse(localStorage.getItem("ernest-cookie-consent") || "null");
          const storedTheme = consent?.preferences ? localStorage.getItem("ernest-theme") : null;
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          const theme = storedTheme || (prefersDark ? "dark" : "light");
          document.documentElement.setAttribute("data-theme", theme);
        } catch {
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          document.documentElement.setAttribute("data-theme", prefersDark ? "dark" : "light");
        }
      })();
    </script>
    <link rel="stylesheet" href="../styles.css" />
  </head>
  <body>
    <div class="page-shell">
      <header class="hero page-hero">
        <nav class="topbar">
          <a class="brand brand-logo" href="../index.html#top" aria-label="ERNEST home">
            <img
              src="../ERNEST_long_blue.svg"
              data-light-src="../ERNEST_long_blue.svg"
              data-dark-src="../ERNEST_long_yellow.svg"
              alt="ERNEST project logo"
            />
          </a>
          <div class="topbar-actions">
            <div class="nav-links">
              <a href="../index.html">Home</a>
              <a href="../about.html">About ERNEST</a>
              <a href="../escape-rooms.html">Escape Rooms</a>
              <a href="../network.html">The Network</a>
            </div>
            <button
              class="theme-toggle"
              type="button"
              aria-label="Toggle color theme"
              aria-pressed="false"
            >
              <span class="theme-toggle-sun" aria-hidden="true">
                <svg viewBox="0 0 24 24" class="theme-icon" focusable="false">
                  <circle cx="12" cy="12" r="4.5" fill="currentColor" />
                  <g stroke="currentColor" stroke-linecap="round" stroke-width="1.8" fill="none">
                    <path d="M12 1.8v3.2" />
                    <path d="M12 19v3.2" />
                    <path d="M1.8 12H5" />
                    <path d="M19 12h3.2" />
                    <path d="M4.4 4.4l2.2 2.2" />
                    <path d="M17.4 17.4l2.2 2.2" />
                    <path d="M19.6 4.4l-2.2 2.2" />
                    <path d="M6.6 17.4l-2.2 2.2" />
                  </g>
                </svg>
              </span>
              <span class="theme-toggle-moon" aria-hidden="true">
                <svg viewBox="0 0 24 24" class="theme-icon" focusable="false">
                  <path
                    d="M16.8 15.9A8.2 8.2 0 0 1 8.1 7.2a8.8 8.8 0 0 1 .2-1.8 8.9 8.9 0 1 0 10.3 10.3 8.8 8.8 0 0 1-1.8.2Z"
                    fill="currentColor"
                  />
                </svg>
              </span>
            </button>
          </div>
        </nav>

        <section class="page-hero-layout">
          <div class="hero-stars" aria-hidden="true">
            <span class="star star-xl star-a"></span>
            <span class="star star-md star-b"></span>
            <span class="star star-sm star-c"></span>
            <span class="star star-md star-d"></span>
          </div>
          <div class="hero-cat-mark" aria-hidden="true"></div>
          <div class="hero-copy hero-copy-full">
            <p class="eyebrow">Cookie Policy</p>
            <h1>Cookie Policy for the ERNEST website.</h1>
            <p class="lead">
              Replace this page with the full text of your EU cookie policy.
            </p>
          </div>
        </section>
      </header>

      <main>
        <section class="section">
          <div class="section-heading">
            <p class="section-kicker">Draft Page</p>
            <h2>Update this page with your official policy text.</h2>
            <p class="section-note">
              Suggested sections: data controller, technical cookies in use, storage duration,
              legal basis, how preferences are stored, and user rights.
            </p>
          </div>
          <article class="card">
            <h3>Placeholder content</h3>
            <p>
              This page is intentionally ready to be edited. You can replace this text
              with the final cookie policy for ERNEST and keep the URL path as
              <strong>/cookie-policy-eu</strong> when deployed.
            </p>
          </article>
        </section>
      </main>

      <footer class="footer">
        <p>ERNEST • European Researchers' Night Escape Science Team</p>
        <p>Cookie policy placeholder page.</p>
      </footer>
    </div>
    <script src="../site.js"></script>
  </body>
</html>
